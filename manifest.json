{
  "manifest_version": 3,
  "name": "Own Tweets CSV",
  "version": "1.0.0",
  "description": "Minimal local-only Chrome extension for exporting your own X posts as CSV.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Own Tweets CSV"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://x.com/*", "https://*.x.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["https://x.com/*", "https://*.x.com/*"],
      "run_at": "document_idle"
    }
  ]
}
